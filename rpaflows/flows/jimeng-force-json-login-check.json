{
  "flow": {
    "id": "jimeng_force_json_login_check",
    "start": "step_1",
    "args": {},
    "vars": {
      "login.result": {
        "type": "any",
        "desc": "invoke 强制执行 JSON 版 login_check_ensure 的结果",
        "from": ""
      }
    },
    "steps": [
      {
        "id": "step_1",
        "action": {
          "type": "goto",
          "url": "https://jimeng.jianying.com/ai-tool/home",
          "postWaitMs": 2000
        },
        "next": {
          "done": "step_2",
          "failed": "abort_1"
        }
      },
      {
        "id": "step_2",
        "action": {
          "type": "invoke",
          "target": "login_check_ensure#login-check-ensure_1a6qrp5",
          "args": {
            "ensure": true,
            "login.ensure": true
          }
        },
        "next": {
          "done": "done_1",
          "failed": "abort_1"
        },
        "saveAs": "login.result"
      },
      {
        "id": "done_1",
        "action": {
          "type": "done",
          "reason": "已打开网页并强制调用 JSON 版 login_check_ensure",
          "conclusion": {
            "status": "done",
            "value": "${vars.login.result}"
          }
        },
        "next": {}
      },
      {
        "id": "abort_1",
        "action": {
          "type": "abort",
          "reason": "打开网页或登录确认失败"
        },
        "next": {}
      }
    ]
  }
}
