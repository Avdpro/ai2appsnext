        "saveAs": "search_results_present_after_fallback",
        "next": "check_search_results_after_fallback"
      },
      {
        "id": "check_search_results_after_fallback",
        "action": {
          "type": "branch",
          "cases": [
            {
              "when": {
                "source": "vars",
                "path": "search_results_present_after_fallback",
                "op": "truthy"
