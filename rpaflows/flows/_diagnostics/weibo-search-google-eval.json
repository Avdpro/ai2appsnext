              "url",
              "title",
              "text",
              "authorId",
              "authorName",
              "publishTime",
              "likeCount",
              "commentCount",
              "repostCount",
              "media"
            ],
            "read.requireFields": [
              "postId",
              "url",
              "text",
              "authorName"
            ],
            "read.minItems": "${{ args.minItems || 1 }}"
          }
        },
        "next": "load_and_read_more_weibo_posts"
      },
      {
        "id": "load_and_read_more_weibo_posts",
        "action": {
          "type": "invoke",
          "find": {
            "kind": "rpa",
            "must": [
              "loadMore"
            ]
          },
          "args": {
            "loadMore.target": "div.card-wrap, .weibo-list, article.weibo-post",
            "loadMore.minNewItems": "${{ args.minNewItems || 1 }}",
            "loadMore.maxTries": "${{ args.scrollRounds || 3 }}",
            "read.fields": [
              "postId",
              "url",
              "title",
              "text",
              "authorId",
              "authorName",
              "publishTime",
              "likeCount",
              "commentCount",
              "repostCount",
              "media"
            ],
            "read.requireFields": [
              "postId",
              "url",
              "text",
              "authorName"
            ]
          }
        },
        "next": "combine_results"
