      },
      {
        "id": "fallback_click_search_button",
        "action": {
          "type": "click",
          "query": "button[type='submit'][aria-label*='搜索'], button[type='submit'][title*='搜索'], .search_button, .search_icon",
          "postWaitMs": 2000
        },
        "next": "wait_after_fallback_click"
      },
      {
        "id": "wait_after_fallback_click",
        "action": {
          "type": "wait",
          "query": "div.card-wrap, .weibo-list, article.weibo-post",
          "state": "visible",
          "timeoutMs": 5000
