        "id": "combine_results",
        "action": {
          "type": "run_js",
          "code": "(args, opts, vars, result) => { const initial = vars.read_initial_weibo_posts.result || []; const more = vars.load_and_read_more_weibo_posts.result || []; return [...initial, ...more]; }"
        },
        "saveAs": "all_weibo_posts",
        "next": "done_success"
      },
      {
        "id": "done_success",
        "action": {
          "type": "done",
          "reason": "Successfully retrieved Weibo posts.",
          "conclusion": "${vars.all_weibo_posts}"
        }
      }
    ]
  }
