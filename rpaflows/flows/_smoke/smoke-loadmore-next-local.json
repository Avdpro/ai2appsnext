{
  "id": "smoke_loadmore_next_local",
  "start": "go",
  "steps": [
    {
      "id": "go",
      "action": {
        "type": "goto",
        "url": "http://127.0.0.1:8787/loadmore/next-page-load.html",
        "waitBy": "css: #item-list",
        "waitTimeoutMs": 8000
      },
      "next": { "done": "invoke", "failed": "abort" }
    },
    {
      "id": "invoke",
      "action": {
        "type": "invoke",
        "find": {
          "kind": "rpa",
          "must": ["loadMore"],
          "prefer": ["loadMore.result"]
        },
        "args": {
          "loadMore.target.selector": "#item-list",
          "loadMore.minNewItems": 8,
          "loadMore.maxTries": 3
        },
        "returnTo": "caller",
        "onError": "fail"
      },
      "saveAs": "invokeOut",
      "next": { "done": "verify", "failed": "abort" }
    },
    {
      "id": "verify",
      "action": {
        "type": "run_js",
        "scope": "page",
        "code": "function(){ const count=document.querySelectorAll('#item-list > li').length; return { ok: count>=16, count }; }"
      },
      "saveAs": "verifyOut",
      "next": { "done": "route_verify", "failed": "abort" }
    },
    {
      "id": "route_verify",
      "action": {
        "type": "branch",
        "cases": [
          { "when": { "op": "eq", "source": "vars", "path": "verifyOut.ok", "value": true }, "to": "done" }
        ],
        "default": "abort_verify"
      },
      "next": {}
    },
    {
      "id": "done",
      "action": {
        "type": "done",
        "reason": "smoke loadmore next local passed",
        "conclusion": "${{ ({ ok:true, count:vars.verifyOut.count, invoke:vars.invokeOut||null }) }}"
      }
    },
    {
      "id": "abort_verify",
      "action": {
        "type": "abort",
        "reason": "verify failed: count=${vars.verifyOut.count}"
      }
    },
    {
      "id": "abort",
      "action": {
        "type": "abort",
        "reason": "smoke loadmore next local failed"
      }
    }
  ]
}
