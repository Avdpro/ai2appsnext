{
  "id": "smoke_read_comments_local",
  "start": "go",
  "steps": [
    {
      "id": "go",
      "action": {
        "type": "goto",
        "url": "http://127.0.0.1:8787/comments/comments-list.html",
        "waitBy": "css: #comment-list .comment",
        "waitTimeoutMs": 8000
      },
      "next": { "done": "invoke", "failed": "abort" }
    },
    {
      "id": "invoke",
      "action": {
        "type": "invoke",
        "target": "read_comments_on_current_page",
        "args": {
          "read.action": "comments",
          "read.minItems": 8,
          "read.fields": ["id", "author", "text", "summary", "time", "url"],
          "read.requireFields": ["author", "text"],
          "read.output": "json",
          "read.target": { "selector": "#comment-list .comment" },
          "query": "comments list",
          "ensure.maxRounds": 3
        },
        "onError": "fail",
        "returnTo": "caller"
      },
      "saveAs": "out",
      "next": { "done": "verify", "failed": "abort" }
    },
    {
      "id": "verify",
      "action": {
        "type": "run_js",
        "scope": "agent",
        "code": "function(out){ const o=(out&&typeof out==='object')?out:{}; const action=String(o.action||''); const items=Array.isArray(o.items)?o.items:[]; const ensure=(o.ensure&&typeof o.ensure==='object')?o.ensure:{}; const enough=!!ensure.enough; const everyText=items.every((it)=>String(it&&it.text||'').trim().length>0); const everyAuthor=items.every((it)=>String(it&&it.author||'').trim().length>0); const ok=action==='comments' && items.length>=8 && enough && everyText && everyAuthor; return { ok, action, count:items.length, enough, round:Number(ensure.round||0), everyText, everyAuthor }; }",
        "args": ["${{ vars.out || {} }}"]
      },
      "saveAs": "verifyOut",
      "next": { "done": "route_verify", "failed": "abort" }
    },
    {
      "id": "route_verify",
      "action": {
        "type": "branch",
        "cases": [
          { "when": { "op": "eq", "source": "vars", "path": "verifyOut.ok", "value": true }, "to": "done" }
        ],
        "default": "abort_verify"
      },
      "next": {}
    },
    {
      "id": "done",
      "action": {
        "type": "done",
        "reason": "smoke read comments local passed",
        "conclusion": "${{ ({ ok:true, verify:vars.verifyOut, out:vars.out }) }}"
      }
    },
    {
      "id": "abort_verify",
      "action": {
        "type": "abort",
        "reason": "verify failed: action=${vars.verifyOut.action}, count=${vars.verifyOut.count}, enough=${vars.verifyOut.enough}, round=${vars.verifyOut.round}"
      }
    },
    {
      "id": "abort",
      "action": {
        "type": "abort",
        "reason": "smoke read comments local failed"
      }
    }
  ]
}
