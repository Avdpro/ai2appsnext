{
  "id": "flow_prompt_persist_nav_smoke",
  "start": "goto_start",
  "steps": [
    {
      "id": "goto_start",
      "action": {
        "type": "goto",
        "url": "http://127.0.0.1:8787/prompt-nav/index.html",
        "waitBy": "css: #start-nav",
        "waitTimeoutMs": 8000
      },
      "next": { "done": "click_nav_button", "failed": "abort" }
    },
    {
      "id": "click_nav_button",
      "action": {
        "type": "click",
        "by": "css: #start-nav"
      },
      "next": { "done": "ask_user", "failed": "abort" }
    },
    {
      "id": "ask_user",
      "action": {
        "type": "ask_assist",
        "reason": "测试 Prompt 跨导航恢复：页面将在约 3 秒后跳转到 next.html。请观察 Prompt 是否在跳转后仍自动出现。确认后点击“已处理，继续”。",
        "waitUserAction": true,
        "modal": false,
        "mask": false,
        "persistAcrossNav": true,
        "persistTtlMs": 90000,
        "reopenDelayMs": 150
      },
      "next": { "done": "done", "failed": "abort" }
    },
    {
      "id": "done",
      "action": { "type": "done", "conclusion": { "ok": true, "test": "prompt_persist_nav" } }
    },
    {
      "id": "abort",
      "action": { "type": "abort", "reason": "prompt persist nav smoke failed" }
    }
  ]
}
