{
  "id": "smoke_readlist_ensure_local",
  "start": "go",
  "steps": [
    {
      "id": "go",
      "action": {
        "type": "goto",
        "url": "http://127.0.0.1:8787/loadmore/next-page-load.html",
        "waitBy": "css: #item-list",
        "waitTimeoutMs": 8000
      },
      "next": { "done": "invoke", "failed": "abort" }
    },
    {
      "id": "invoke",
      "action": {
        "type": "invoke",
        "target": "read_list_on_current_page",
        "args": {
          "read.action": "list",
          "read.minItems": 16,
          "read.fields": ["url", "title", "summary"],
          "read.output": "json",
          "read.target": { "selector": "#item-list" },
          "query": "item list",
          "ensure.maxRounds": 3
        },
        "onError": "fail",
        "returnTo": "caller"
      },
      "saveAs": "out",
      "next": { "done": "verify", "failed": "abort" }
    },
    {
      "id": "verify",
      "action": {
        "type": "run_js",
        "scope": "agent",
        "code": "function(out){ const o=(out&&typeof out==='object')?out:{}; const items=Array.isArray(o.items)?o.items:[]; const ensure=(o.ensure&&typeof o.ensure==='object')?o.ensure:{}; const enough=!!ensure.enough; const itemCount=Number.isFinite(Number(ensure.itemCount))?Number(ensure.itemCount):items.length; const round=Number.isFinite(Number(ensure.round))?Number(ensure.round):0; const ok=enough && itemCount>=16 && items.length>=16; return { ok, itemCount, listSize: items.length, round, ensure }; }",
        "args": ["${{ vars.out || {} }}"]
      },
      "saveAs": "verifyOut",
      "next": { "done": "route_verify", "failed": "abort" }
    },
    {
      "id": "route_verify",
      "action": {
        "type": "branch",
        "cases": [
          { "when": { "op": "eq", "source": "vars", "path": "verifyOut.ok", "value": true }, "to": "done" }
        ],
        "default": "abort_verify"
      },
      "next": {}
    },
    {
      "id": "done",
      "action": {
        "type": "done",
        "reason": "smoke readlist ensure local passed",
        "conclusion": "${{ ({ ok:true, verify:vars.verifyOut, out:vars.out }) }}"
      }
    },
    {
      "id": "abort_verify",
      "action": {
        "type": "abort",
        "reason": "verify failed: itemCount=${vars.verifyOut.itemCount}, listSize=${vars.verifyOut.listSize}, round=${vars.verifyOut.round}"
      }
    },
    {
      "id": "abort",
      "action": {
        "type": "abort",
        "reason": "smoke readlist ensure local failed"
      }
    }
  ]
}
