{
  "id": "smoke_ai_extract_local",
  "start": "go",
  "steps": [
    {
      "id": "go",
      "action": {
        "type": "goto",
        "url": "http://127.0.0.1:8787/article/simple-article.html",
        "waitBy": "css: #article-root",
        "waitTimeoutMs": 8000
      },
      "next": { "done": "invoke", "failed": "abort" }
    },
    {
      "id": "invoke",
      "action": {
        "type": "invoke",
        "target": "ai_extract_generic",
        "args": {
          "ai.extract": {
            "goal": "提取文章核心字段",
            "fields": ["title", "summary", "author"],
            "requireFields": ["title", "summary"],
            "schema": {
              "type": "object",
              "properties": {
                "title": { "type": "string" },
                "summary": { "type": "string" },
                "author": { "type": "string" }
              },
              "required": ["title", "summary"],
              "additionalProperties": true
            },
            "model": "advanced"
          }
        },
        "onError": "fail",
        "returnTo": "caller"
      },
      "saveAs": "out",
      "next": { "done": "verify", "failed": "abort" }
    },
    {
      "id": "verify",
      "action": {
        "type": "run_js",
        "scope": "agent",
        "code": "function(out){ const o=(out&&typeof out==='object')?out:{}; const action=String(o.action||''); const d=(o.data&&typeof o.data==='object')?o.data:{}; const title=String(d.title||''); const summary=String(d.summary||''); const missing=Array.isArray(o.missingFields)?o.missingFields:[]; const ok=action==='extract' && title.toLowerCase().includes('acefox') && summary.length>30 && missing.length===0; return { ok, action, title, summaryLen: summary.length, missingCount: missing.length }; }",
        "args": ["${{ vars.out || {} }}"]
      },
      "saveAs": "verifyOut",
      "next": { "done": "route_verify", "failed": "abort" }
    },
    {
      "id": "route_verify",
      "action": {
        "type": "branch",
        "cases": [
          { "when": { "op": "eq", "source": "vars", "path": "verifyOut.ok", "value": true }, "to": "done" }
        ],
        "default": "abort_verify"
      },
      "next": {}
    },
    {
      "id": "done",
      "action": {
        "type": "done",
        "reason": "smoke ai extract local passed",
        "conclusion": "${{ ({ ok:true, verify:vars.verifyOut, out:vars.out }) }}"
      }
    },
    {
      "id": "abort_verify",
      "action": {
        "type": "abort",
        "reason": "verify failed: action=${vars.verifyOut.action}, title=${vars.verifyOut.title}, summaryLen=${vars.verifyOut.summaryLen}, missing=${vars.verifyOut.missingCount}"
      }
    },
    {
      "id": "abort",
      "action": {
        "type": "abort",
        "reason": "smoke ai extract local failed"
      }
    }
  ]
}
