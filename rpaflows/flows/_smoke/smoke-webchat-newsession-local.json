{
  "id": "smoke_webchat_newsession_local",
  "start": "go",
  "steps": [
    {
      "id": "go",
      "action": {
        "type": "goto",
        "url": "http://127.0.0.1:8787/webchat/chatgpt-mock.html",
        "waitBy": "css: [data-role='new-session']",
        "waitTimeoutMs": 8000
      },
      "next": { "done": "invoke", "failed": "abort" }
    },
    {
      "id": "invoke",
      "action": {
        "type": "invoke",
        "target": "webchat_core",
        "args": {
          "webChat.action": "newSession",
          "webChat.session": {
            "kind": "ai",
            "title": "Test Session A"
          }
        },
        "onError": "fail",
        "returnTo": "caller"
      },
      "saveAs": "out",
      "next": { "done": "verify", "failed": "abort" }
    },
    {
      "id": "verify",
      "action": {
        "type": "run_js",
        "scope": "agent",
        "code": "function(out){ const o=(out&&typeof out==='object')?out:{}; const a=String(o.action||''); const created=!!o.created; const s=(o.session&&typeof o.session==='object')?o.session:{}; const kind=String(s.kind||''); const title=String(s.title||''); const ok=a==='newSession' && created && kind==='ai' && title.length>0; return { ok, action:a, created, kind, title }; }",
        "args": ["${{ vars.out || {} }}"]
      },
      "saveAs": "verifyOut",
      "next": { "done": "route_verify", "failed": "abort" }
    },
    {
      "id": "route_verify",
      "action": {
        "type": "branch",
        "cases": [
          { "when": { "op": "eq", "source": "vars", "path": "verifyOut.ok", "value": true }, "to": "done" }
        ],
        "default": "abort_verify"
      },
      "next": {}
    },
    {
      "id": "done",
      "action": {
        "type": "done",
        "reason": "smoke webchat newSession local passed",
        "conclusion": "${{ ({ ok:true, verify:vars.verifyOut, out:vars.out }) }}"
      }
    },
    {
      "id": "abort_verify",
      "action": {
        "type": "abort",
        "reason": "verify failed: action=${vars.verifyOut.action}, created=${vars.verifyOut.created}, kind=${vars.verifyOut.kind}, title=${vars.verifyOut.title}"
      }
    },
    {
      "id": "abort",
      "action": {
        "type": "abort",
        "reason": "smoke webchat newSession local failed"
      }
    }
  ]
}
