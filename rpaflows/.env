WEBDRIVE_APP=/Users/avdpropang/sdk/moz/firefox/obj-aarch64-apple-darwin/dist/Acefox.app
WEBRPA_DATADIR=/Users/avdpropang/sdk/cchome/home/rpaflows/.webdrive-profiles
WEBRPA_WEBDRIVE_MODE=direct

AI_RUN_JS_USE_ADVANCED=1
AI_MODEL_RUN_JS_VERIFY=gpt-5-mini
AI_MODEL_RUN_JS_VERIFY_FALLBACK=gpt-4.1
AI_TEMPERATURE_SELECTOR=0
AI_TEMPERATURE_RUN_AI=0
AI_TEMPERATURE_RUN_JS=0
AI_RETRY_SELECTOR=2
AI_RETRY_RUN_AI=2
AI_RETRY_RUN_JS=2
AI_MAX_SELECTORS=5
AI_HTML_MAXLEN_SELECTOR=120000
AI_HTML_MAXLEN_RUN_AI=120000
AI_HTML_MAXLEN_RUN_JS=80000
AI_RUN_JS_CODE_MAX_CHARS=12000
AI_RUN_JS_CODE_MAX_LINES=260
AI_RUN_JS_REPEAT_PATTERN_LIMIT=12
AI_PROMPT_VERSION_RUN_JS=4
AI_RUN_JS_VERIFY_ENABLED=1
AI_RUN_JS_VERIFY_MAX_CYCLES=3
AI_RUN_JS_VERIFY_HTML_MAXLEN=50000
AI_RUN_JS_VERIFY_RESULT_MAXLEN=12000
AI_RUN_JS_VERIFY_PROMPT_VERSION=1

# ===== Multi-provider routing (default + per-purpose override) =====
# default: openai | openrouter | ollama | google | anthropic
AI_PROVIDER=openrouter
# AI_PROVIDER_FALLBACK=anthropic
# Per-purpose provider override (optional)
# AI_PROVIDER_SELECTOR=ollama
# AI_PROVIDER_SELECTOR_FALLBACK=openai
# AI_PROVIDER_RUN_AI=openai
# AI_PROVIDER_RUN_AI_FALLBACK=anthropic
# AI_PROVIDER_RUN_JS=anthropic
# AI_PROVIDER_RUN_JS_FALLBACK=openai


OPENAI_API_KEY=[YOUR KEY]
OPENAI_MODEL=gpt-5.2
OPENAI_MODEL_FALLBACK=gpt-5.2
OPENAI_MODEL_FAST=gpt-5-mini
OPENAI_MODEL_BALANCED=gpt-5.2
OPENAI_MODEL_QUALITY=gpt-5.2
OPENAI_MODEL_ADVANCED=gpt-5.2
OPENAI_MODEL_ADVANCED_FALLBACK=gpt-5.2
OPENAI_MODEL_VISION=gpt-5.2
OPENAI_MODEL_RUN_JS=gpt-5.2
OPENAI_MODEL_RUN_JS_FALLBACK=gpt-4o-mini
OPENAI_MODEL_RUN_JS_ADVANCED=gpt-5.2
OPENAI_MODEL_RUN_JS_ADVANCED_FALLBACK=gpt-5-mini

# ===== Ollama =====
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:14b-instruct
OLLAMA_MODEL_BALANCED=qwen2.5:14b-instruct
OLLAMA_MODEL_QUALITY=deepseek-r1:14b
OLLAMA_MODEL_RUN_AI_BALANCED=qwen2.5:14b-instruct
OLLAMA_MODEL_SELECTOR_BALANCED=qwen2.5:14b-instruct
OLLAMA_MODEL_RUN_JS_BALANCED=qwen2.5:14b-instruct

# ===== Google (Gemini) =====
GOOGLE_API_KEY=[YOUR KEY]
GOOGLE_MODEL=gemini-3.1-pro-preview
GOOGLE_MODEL_ADVANCED=gemini-3.1-pro-preview
GOOGLE_MODEL_QUALITY=gemini-3.1-pro-preview
GOOGLE_MODEL_BALANCED=gemini-3.1-pro-preview
GOOGLE_MODEL_FAST=gemini-3-flash-preview
GOOGLE_MODEL_RUN_AI_BALANCED=gemini-3.1-pro-preview
GOOGLE_MODEL_SELECTOR_BALANCED=gemini-3.1-pro-preview
GOOGLE_MODEL_RUN_JS_BALANCED=gemini-3.1-pro-preview

# ===== Claude (Anthropic) =====
ANTHROPIC_API_KEY=[YOUR KEY]
ANTHROPIC_VERSION=2023-06-01
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MODEL_ADVANCED=claude-opus-4-6
CLAUDE_MODEL_QUALITY=claude-opus-4-6
CLAUDE_MODEL_BALANCED=claude-sonnet-4-6
CLAUDE_MODEL_FAST=claude-sonnet-4-6
CLAUDE_MODEL_RUN_AI_BALANCED=claude-sonnet-4-6
CLAUDE_MODEL_SELECTOR_BALANCED=claude-sonnet-4-6
CLAUDE_MODEL_RUN_JS_BALANCED=cclaude-sonnet-4-6

# ===== JSON repair (provider-agnostic fallback for run_ai envelope) =====
AI_JSON_REPAIR_ENABLED=1
# 留空表示跟随当前请求 provider；可指定 openai|openrouter|ollama|google|anthropic
AI_JSON_REPAIR_PROVIDER=
# 留空表示按 repair provider 自动选择 fast 模型
AI_JSON_REPAIR_MODEL=
AI_JSON_REPAIR_TIMEOUT_MS=60000
AI_JSON_REPAIR_MAX_INPUT_CHARS=16000

OPENROUTER_API_KEY=[YOUR KEY]
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-sonnet-4-6
OPENROUTER_MODEL_ADVANCED=anthropic/claude-opus-4-6
OPENROUTER_MODEL_QUALITY=anthropic/claude-opus-4-6
OPENROUTER_MODEL_BALANCED=openai/gpt-5.2
OPENROUTER_MODEL_FAST=openai/gpt-5-mini
